void mexFunction( int nlhs, mxArray *plhs[],=0A=
                  int nrhs, const mxArray *prhs[] )=0A=
{		=0A=
    /* Check input arguments */=0A=
    if (nrhs < 4)=0A=
    {=0A=
        showHelp();=0A=
		mexErrMsgTxt("at least 4 input arguments required (mode =3D=3D1)");=0A=
        return;=0A=
    }=0A=
    if( nrhs > 6 )=0A=
    {=0A=
        showHelp();=0A=
        mexErrMsgTxt("maximum 6 input arguments required");=0A=
    }=0A=
    if(nlhs > 1)=0A=
    {=0A=
        showHelp();=0A=
        mexErrMsgTxt("only one output arguments is defined. ");=0A=
    }=0A=
	=0A=
	// mode=0A=
	if( mxGetM(prhs[0]) * mxGetN(prhs[0]) !=3D 1 )=0A=
	{=0A=
		showHelp();=0A=
		mexErrMsgTxt("mode is a single number 1: dep only, 2,3: dep and rep");=0A=
	}=0A=
	mMode =3D (int)mxGetScalar(prhs[0]);	=0A=
	=0A=
	// maxt=0A=
	if( mxGetM(prhs[1]) > 1  || mxGetN(prhs[1]) > 1 )=0A=
	{=0A=
		showHelp();=0A=
		mexErrMsgTxt("maxt is a single number");=0A=
	}=0A=
	mMaxt =3D (int)mxGetScalar(prhs[1]);=0A=
	=0A=
// ADJ=0A=
		if ( mxGetN(prhs[2]) =3D=3D mxGetM(prhs[2]) ) //ADJ=0A=
		{=0A=
			mADJ =3D mxGetPr(prhs[2]);=0A=
			mNpnt =3D (int)mxGetM(prhs[2]);=0A=
		}=0A=
        else=0A=
        {=0A=
            showHelp();=0A=
            mexErrMsgTxt("size ADJ =3D [n, n]");=0A=
        }=0A=
=0A=
	// dep=0A=
	if( !(mxIsDouble(prhs[3])) && =0A=
		 (int)(mxGetM(prhs[3]) * mxGetN(prhs[3])) !=3D mNpnt )=0A=
	{=0A=
		showHelp();=0A=
		mexErrMsgTxt("dep(n,1) of type double");=0A=
