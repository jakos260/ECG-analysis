/*                                                                       =
  */           =0A=
/* This program calculates the shortest paths between one vertex and all =
  */=0A=
/* the other vertices of a triangulated object.                          =
  */=0A=
/* The program creates matrix of 1 by number of vertices.				   */=0A=
/* Input:  An adjaceny matrix (file) with the distances between the      =
  */=0A=
/*         adjacent vertices                                             =
  */=0A=
/* Output: A matrix with all shortest paths between the all vertices.    =
  */=0A=
/*                                                                       =
  */=0A=
/* 20-2-14   Peter van Dam                                               =
  */=0A=
/*			  Peacs						                                   */  =0A=
/*                                                                       =
  */=0A=
/************************************************************************=
***/=0A=
=0A=
#include <mex.h>=0A=
#include <math.h>=0A=
=0A=
/************************* Definitions and global =
**************************/=0A=
=0A=
int		mNpnt		=3D 0;=0A=
int 	mMaxt		=3D 0;=0A=
int 	mMode		=3D 1;=0A=
int 	mSourceVersion  =3D 0;=0A=
int    *mNeighDep	=3D NULL;=0A=
double *mS  		=3D NULL;=0A=
const double *mADJ		=3D NULL;=0A=
const double *mDep		=3D NULL;=0A=
