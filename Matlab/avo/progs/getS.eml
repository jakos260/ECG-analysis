}=0A=
=0A=
=0A=
int outofmem(void)=0A=
{=0A=
    mexErrMsgTxt("Out of memory.");=0A=
    return 1;=0A=
}=0A=
=0A=
void computedSrowDep(int ir,double * rowS )=0A=
{=0A=
	int i, ti, curDepI, maxToZeroT,mint,maxt;=0A=
	int Nneigh;=0A=
	double t, slope,factor; =0A=
	const double *rowAdj;=0A=
    =0A=
	rowAdj 		=3D &mADJ[ir * mNpnt];=0A=
	=0A=
	curDepI =3D floor( mDep[ir] + 0.499 );=0A=
	maxToZeroT 	=3D curDepI;=0A=
=0A=
	Nneigh =3D 0;=0A=
	for (i=3D0; i < mNpnt; i++ )=0A=
	{			=0A=
		if ( rowAdj[i] > 0 )=0A=
		{=0A=
			mNeighDep[Nneigh] =3D floor( mDep[i] + 0.4999);=0A=
=0A=
			if ( mNeighDep[Nneigh] > maxToZeroT )=0A=
			{=0A=
				maxToZeroT =3D mNeighDep[Nneigh];=0A=
			}=0A=
			Nneigh++;=0A=
		}		=0A=
	}=0A=
	if ( maxToZeroT >=3D mMaxt )=0A=
	{=0A=
		maxToZeroT =3D mMaxt - 1;=0A=
	}=0A=
	=0A=
    for (ti =3D 0; ti <=3D maxToZeroT; ti++ )=0A=
    {=0A=
        rowS[ti] =3D 0;=0A=
    }=0A=
	for ( ; ti < mMaxt; ti++ )=0A=
	{=0A=
		rowS[ti] =3D 1.0;=0A=
	}=0A=
=0A=
    factor =3D 1.0 / (double) Nneigh;=0A=
    for (i =3D 0; i < Nneigh; i++ )=0A=
    {=0A=
		mint =3D ( curDepI < mNeighDep[i] ) ? curDepI : mNeighDep[i];=0A=
		if ( mint < mMaxt )=0A=
		{=0A=
			maxt =3D ( curDepI > mNeighDep[i] ) ? curDepI : mNeighDep[i];=0A=
			if ( maxt > mMaxt )=0A=
			{=0A=
				maxt =3D mMaxt;=0A=
			}=0A=
=0A=
			slope =3D factor / (double)(maxt - mint);=0A=
			t =3D 0;        =0A=
			for ( ti =3D mint; ti < maxt; ti++, t +=3D 1.0 )=0A=
			{=0A=
				rowS[ti] +=3D slope * t;            =0A=
			}=0A=
=0A=
			for ( ; ti <=3D maxToZeroT; ti++)=0A=
			{=0A=
				rowS[ti] +=3D factor;=0A=
			}=0A=
		}=0A=
    }=0A=
}=0A=
=0A=
=0A=
=0A=
void getS( )=0A=
{     =0A=
	int t, ir;=0A=
	double tdep, trep, maxAmpl, sumY, vali;=0A=
	double *rowS;=0A=
	double *y;=0A=
=0A=
	y =3D mxCalloc(mMaxt, sizeof(double));	y || outofmem();=0A=
	=0A=
	mNeighDep =3D mxCalloc(mNpnt, sizeof(int));	mNeighDep || outofmem();=0A=
	=0A=
    for ( ir =3D 0; ir < mNpnt; ir++ )=0A=
    {		=0A=
        rowS =3D &mS[ ir * mMaxt ];=0A=
		=0A=
        tdep    =3D -mDep[ir];=0A=
        trep    =3D -mRep[ir];=0A=
        maxAmpl =3D -1e6;=0A=
=0A=
        if ( 0 ) // will create a spiky signal due to the steep upslope=0A=
        {=0A=
            for ( t =3D 0; t < mMaxt; t++, tdep +=3D 1.0, trep +=3D 1.0 )=0A=
            {=0A=
                rowS[t] =3D 1.0 /( 1.0 +  exp(-2.0  * tdep ) );=0A=
            }=0A=
            tdep    =3D -mDep[ir];=0A=
        }=0A=
        else=0A=
        {		=0A=
            computedSrowDep( ir, rowS );=0A=
        }=0A=
=0A=
        if ( mMode > 1 )=0A=
        {=0A=
            if ( mSourceVersion =3D=3D 1 )=0A=
            {=0A=
                for ( t =3D 0; t < mMaxt; t++, tdep +=3D 1.0, trep +=3D =
1.0 )=0A=
                {=0A=
                    vali =3D( 1.0 / ( 1.0 + exp( mRepParams[0] * trep ) =
) ) *=0A=
                          ( 1.0 / ( 1.0 + exp( mRepParams[1]     * trep =
) ) );=0A=
=0A=
                    rowS[t] =3D vali * rowS[t];=0A=
=0A=
                    vali *=3D 1.0 /( 1.0 +  exp(-2.0 * tdep ) );=0A=
                    maxAmpl =3D maxAmpl > vali ? maxAmpl : vali;=0A=
                }=0A=
            }=0A=
            else // mSourceVersion =3D=3D 0=0A=
            {=0A=
                sumY =3D 0;=0A=
=0A=
                tdep    =3D -mDep[ir];=0A=
                trep    =3D -mRep[ir];=0A=
=0A=
                for ( t =3D 0; t < mMaxt; t++, tdep +=3D 1.0, trep +=3D =
1.0 )=0A=
                {=0A=
                    sumY +=3D   mRepParams[0] +=0A=
                                ( 1 / ( 1 + exp( mRepParams[1] * trep ) =
) ) *=0A=
                                ( 1 / ( 1 + exp( mRepParams[2]     * =
trep ) ) );=0A=
=0A=
                    y[t] =3D sumY; // 1 - cumsum=0A=
                }=0A=
                for (t=3D0; t < mMaxt; t++ )=0A=
                {=0A=
                    rowS[t] *=3D 1- (y[t]/sumY);      // scale between 0 =
- 1=0A=
                                                    // multiply dep and =
rep S =3D S * (1-Y)=0A=
                    maxAmpl =3D maxAmpl > rowS[t] ? maxAmpl : rowS[t];=0A=
                }=0A=
=0A=
=0A=
            }=0A=
            // For the future when dealing with ischemic areas=0A=
            //        maxAmpl *=3D ampl.at(ir);// devide by maxAmpl to =
normalize=0A=
            for (t=3D0; t < mMaxt; t++ ) // scale between 0 - 1=0A=
            {=0A=
                rowS[t] /=3D maxAmpl;=0A=
            }=0A=
        }=0A=
    }=0A=
=0A=
	mxFree( y );=0A=
	mxFree( mNeighDep );=0A=
}=0A=
